{
  "manifest_version": 3,
  "name": "Tab Audio Recorder",
  "version": "2.2.0",
  "description": "再生中タブの音声を録音して保存する拡張。ポップアップから録音の開始/停止と各種設定（ミュート録音・自動停止・形式）ができます。",
  "permissions": ["tabCapture", "offscreen", "downloads", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "タブ音声レコーダー"
  },
  "minimum_chrome_version": "116"
}
